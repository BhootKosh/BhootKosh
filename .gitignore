# ============================================================
# BhootKosh — .gitignore
# Next.js · React · TypeScript · Prisma · Node · Vercel
# ============================================================

# ---------- Dependencies ----------
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.pnpm-store/

# ---------- Next.js ----------
.next/
out/
.swc/
next-env.d.ts

# ---------- Build / production ----------
build/
dist/
*.tsbuildinfo

# ---------- Environment & secrets ----------
# Keep .env.example committed as a template only
.env
.env.*
!.env.example
!.env.sample
!.env.template
*.pem
*.key
secrets/
credentials/
.env.credentials.local
.env.vercel.local

# ---------- Prisma ----------
# Local SQLite (if ever used); Mongo connection stays in env
/prisma/*.db
/prisma/*.db-journal
/prisma/*.db-shm
/prisma/*.db-wal
/prisma/migrations/**/migration_lock.toml.bak

# ---------- Logs & debug ----------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-debug.log*
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# ---------- Testing & coverage ----------
coverage/
.nyc_output/
*.lcov
playwright-report/
test-results/
blob-report/
.vitest/
jest-cache/

# ---------- Vercel / deploy ----------
.vercel
.netlify

# ---------- Caches & tooling ----------
.cache/
.turbo/
.parcel-cache/
.eslintcache
.stylelintcache
*.pid
*.seed
*.pid.lock

# ---------- OS junk ----------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---------- Editors / IDEs ----------
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# ---------- Optional local notes ----------
*.local
.local/
TODO.local.md
NOTES.local.md

# ---------- Uploads / temp (local only) ----------
tmp/
temp/
.tmp/
.temp/
uploads/
!public/

# ---------- Storybook (if added later) ----------
storybook-static/

# ---------- Sentry / monitoring (if added) ----------
.sentryclirc

# ---------- Misc ----------
*.bak
*.orig
*.rej
.history/
)
