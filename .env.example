# MongoDB (Atlas or local)
# Example Atlas:
# DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/bhootkosh?retryWrites=true&w=majority"
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/bhootkosh?retryWrites=true&w=majority"

# Auth.js / NextAuth (use a long random secret — openssl rand -base64 32)
AUTH_SECRET="generate-a-long-random-string-here"
NEXTAUTH_SECRET="generate-a-long-random-string-here"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Default admin account (used by seed)
ADMIN_EMAIL="admin@bhootkosh.com"
ADMIN_PASSWORD="ChangeMeSecurePassword123!"

# Cloudinary (optional — only needed for admin image uploads)
# Either set CLOUDINARY_URL:
# CLOUDINARY_URL="cloudinary://API_KEY:API_SECRET@CLOUD_NAME"
# Or set the three fields separately:
CLOUDINARY_URL=""
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_FOLDER="bhootkosh"

# Public site URL (SEO, canonical, OG)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
