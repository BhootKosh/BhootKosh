# ============================================================
# BhootKosh — Vercel / production template
# Site: https://bhoot-kosh.vercel.app
#
# Vercel → Project → Settings → Environment Variables
# Add EVERY key below for Production (and Preview if you want).
# Do NOT use localhost values on Vercel.
# ============================================================

# MongoDB Atlas (must allow 0.0.0.0/0 in Network Access)
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/bhootkosh?retryWrites=true&w=majority"

# Auth.js — generate once and keep forever:
# node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
AUTH_SECRET="paste-long-random-secret-here"
NEXTAUTH_SECRET="paste-same-secret-as-AUTH_SECRET"

# Production URLs (no trailing slash)
AUTH_URL="https://bhoot-kosh.vercel.app"
NEXTAUTH_URL="https://bhoot-kosh.vercel.app"
NEXT_PUBLIC_SITE_URL="https://bhoot-kosh.vercel.app"

# Admin (seed only: npx tsx prisma/seed.ts)
ADMIN_EMAIL="admin@bhootkosh.com"
ADMIN_PASSWORD="use-a-long-random-password"

# Cloudinary
CLOUDINARY_URL="cloudinary://API_KEY:API_SECRET@CLOUD_NAME"
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_FOLDER="bhootkosh"
