# ============================================================
# BhootKosh — environment template
# Copy to .env for local dev. On Vercel: Project → Settings →
# Environment Variables → add each key (Production + Preview).
# ============================================================

# ---------- MongoDB Atlas ----------
# Network Access: allow 0.0.0.0/0 (or Vercel IPs) so serverless can connect
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/bhootkosh?retryWrites=true&w=majority"

# ---------- Auth.js / NextAuth ----------
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Keep AUTH_SECRET and NEXTAUTH_SECRET the same value. Never rotate casually (logs users out).
AUTH_SECRET="paste-long-random-secret-here"
NEXTAUTH_SECRET="paste-long-random-secret-here"

# Production (Vercel) — no trailing slash
AUTH_URL="https://bhoot-kosh.vercel.app"
NEXTAUTH_URL="https://bhoot-kosh.vercel.app"

# Local development (comment production lines and use these when running npm run dev)
# AUTH_URL="http://localhost:3000"
# NEXTAUTH_URL="http://localhost:3000"

# ---------- Admin (seed only) ----------
# Used by: npx tsx prisma/seed.ts  → upserts admin user with bcrypt hash
# After changing these, re-run seed against the same DATABASE_URL
ADMIN_EMAIL="admin@bhootkosh.com"
ADMIN_PASSWORD="use-a-long-random-password"

# ---------- Cloudinary (admin image uploads) ----------
# Preferred: single URL  OR  the three separate fields
CLOUDINARY_URL="cloudinary://API_KEY:API_SECRET@CLOUD_NAME"
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_FOLDER="bhootkosh"

# ---------- Public site URL (SEO / OG / absolute links) ----------
# Production:
NEXT_PUBLIC_SITE_URL="https://bhoot-kosh.vercel.app"
# Local:
# NEXT_PUBLIC_SITE_URL="http://localhost:3000"
